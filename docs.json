{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Layer",
  "colors": {
    "primary": "#6C5CE7",
    "light": "#A29BFE",
    "dark": "#5A4BD1"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "openapi": "api-reference/openapi.json",
        "groups": [
          {
            "group": "Overview",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Workspaces",
            "pages": [
              "GET /v1/workspaces",
              "GET /v1/workspaces/{workspace_id}"
            ]
          },
          {
            "group": "Models",
            "pages": [
              "GET /v1/workspaces/{workspace_id}/models",
              "GET /v1/workspaces/{workspace_id}/models/{model_id}"
            ]
          },
          {
            "group": "Workflows",
            "pages": [
              "GET /v1/workspaces/{workspace_id}/workflows",
              "POST /v1/workspaces/{workspace_id}/workflows/{workflow_id}/estimate",
              "POST /v1/workspaces/{workspace_id}/workflows/{workflow_id}/runs",
              "GET /v1/workspaces/{workspace_id}/workflows/{workflow_id}/runs/{run_id}"
            ]
          },
          {
            "group": "Inferences",
            "pages": [
              "POST /v1/workspaces/{workspace_id}/inferences/estimate",
              "POST /v1/workspaces/{workspace_id}/inferences",
              "GET /v1/workspaces/{workspace_id}/inferences/{inference_id}"
            ]
          },
          {
            "group": "Files",
            "pages": [
              "POST /v1/workspaces/{workspace_id}/files"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://app.layer.ai",
          "icon": "browser"
        },
        {
          "anchor": "Blog",
          "href": "https://layer.ai/blog",
          "icon": "newspaper"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "https://help.layer.ai"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open Layer",
      "href": "https://app.layer.ai"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/layerai",
      "github": "https://github.com/layerai",
      "linkedin": "https://linkedin.com/company/layerai",
      "discord": "https://discord.gg/layerai"
    }
  }
}
